# Add this block to your server's Caddyfile.
# Requires an A record: jokestar.mgrushko.dev → <your server IP>

jokestar.mgrushko.dev {
  encode zstd gzip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }

  # Backend API — flush_interval -1 required for SSE
  handle_path /api/* {
    reverse_proxy jokestar-backend:8000 {
      flush_interval -1
    }
  }

  # Frontend SPA
  handle {
    reverse_proxy jokestar-web:80
  }
}
