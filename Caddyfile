# Jokestar routes — paste these blocks inside the existing mgrushko.dev { } site block.
#
# The frontend_dist volume must be mounted into the Caddy container, e.g.:
#   volumes:
#     - crocomoji_frontend_dist:/srv/jokestar:ro
#
# The backend container must be reachable as "backend" from Caddy's network, e.g.:
#   networks: [caddy_default, crocomoji_default]  (or however your setup bridges them)

    # Backend API — strip /jokestar/api prefix before proxying.
    # flush_interval -1 is required for SSE (disables response buffering).
    handle_path /jokestar/api/* {
        reverse_proxy backend:8000 {
            flush_interval -1
        }
    }

    # Frontend SPA — strip /jokestar prefix, fall back to index.html for
    # client-side routes.
    handle_path /jokestar/* {
        root * /srv/jokestar
        try_files {path} /index.html
        file_server
    }

    # Redirect bare /jokestar to /jokestar/
    redir /jokestar /jokestar/ 301
